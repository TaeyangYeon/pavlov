# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pavlov_user:changeme_use_strong_password@postgres:5432/pavlov
TEST_DATABASE_URL=postgresql+asyncpg://pavlov_user:changeme_use_strong_password@localhost:5432/pavlov_test
POSTGRES_USER=pavlov_user
POSTGRES_PASSWORD=changeme_use_strong_password
POSTGRES_DB=pavlov

# ── Application ───────────────────────────────────
APP_ENV=production
SECRET_KEY=generate_with_python_secrets_token_hex_32
ENCRYPTION_KEY=generate_with_fernet_generate_key

# ── AI ────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_COST_ALERT_THRESHOLD_USD=0.10

# ── Scheduler ─────────────────────────────────────
SCHEDULER_ENABLED=true
MAX_RECOVERY_DAYS=3

# ── Market Data ───────────────────────────────────
MARKET_DATA_TIMEOUT_SECONDS=30
KR_TICKERS=005930,000660,035420,005380,000270
US_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA

# ── Notifications ─────────────────────────────────
COOLING_OFF_MINUTES=30
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# ── Performance ───────────────────────────────────
SLOW_QUERY_THRESHOLD_MS=100